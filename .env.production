# 开发者：杰哥网络科技 (qq: 2711793818)
# 环境：生产环境
# 说明：打包部署后前端调用后端API的基础地址

# MacCMS API 基础地址（生产环境使用相对路径或完整域名）
# 部署到根目录时用 /api.php
# 部署到子目录时用 /子目录/api.php
VITE_API_BASE_URL=/api.php

# APP专用API地址（app_api.php，用于Xunsearch搜索等高级功能）
VITE_APP_API_URL=/app_api.php

# 图片基础地址（MacCMS返回相对路径时拼接）
# 如果MacCMS已返回完整URL则不需要配置
# 例如：https://你的域名 或 https://图片CDN域名
VITE_IMAGE_BASE_URL=

# APP名称
VITE_APP_NAME=杰哥影视

# 是否开启调试
VITE_DEBUG=false
