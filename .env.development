# 开发者：杰哥网络科技 (qq: 2711793818)
# 环境：本地开发环境
# 说明：开发时前端调用后端API的基础地址

# MacCMS API 基础地址（开发环境指向本地PHP服务）
VITE_API_BASE_URL=http://localhost/api.php

# APP专用API地址（app_api.php，用于Xunsearch搜索等高级功能）
VITE_APP_API_URL=http://localhost/app_api.php

# 图片基础地址（MacCMS返回相对路径时拼接）
# 如果MacCMS已返回完整URL则不需要配置
VITE_IMAGE_BASE_URL=http://localhost

# APP名称
VITE_APP_NAME=杰哥影视

# 是否开启调试
VITE_DEBUG=true
